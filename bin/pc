#!/bin/bash

# ── Farben ─────────────────────────────────────────────────────
C='\033[0;36m'    # Cyan
G='\033[0;32m'    # Green
Y='\033[1;33m'    # Yellow
WH='\033[1;37m'   # White bold
D='\033[0;37m'    # Dim white
GR='\033[0;90m'   # Gray
R='\033[0;31m'    # Red
B='\033[0;34m'    # Blue
M='\033[0;35m'    # Magenta
N='\033[0m'       # Reset

# ── Daten sammeln ──────────────────────────────────────────────
HOSTNAME=$(hostname -s)
USER=$(whoami)
OS="$(sw_vers -productName) $(sw_vers -productVersion)"
KERNEL=$(uname -r)
ARCH=$(uname -m)
CPU=$(sysctl -n machdep.cpu.brand_string 2>/dev/null || echo "Apple Silicon")
CORES=$(sysctl -n hw.ncpu 2>/dev/null)
RAM_GB=$(($(sysctl -n hw.memsize 2>/dev/null) / 1073741824))

# Netzwerk
LOCAL_IP=$(ipconfig getifaddr en0 2>/dev/null || ipconfig getifaddr en1 2>/dev/null || echo "—")
PUBLIC_IP=$(curl -s --max-time 3 ifconfig.me 2>/dev/null || echo "—")
PUBLIC_IP=$(echo "$PUBLIC_IP" | cut -c1-28)
MAC=$(ifconfig en0 2>/dev/null | awk '/ether/{print $2}')
GATEWAY=$(netstat -nr 2>/dev/null | grep default | head -1 | awk '{print $2}')
DNS=$(scutil --dns 2>/dev/null | grep "nameserver\[0\]" | head -1 | awk '{print $3}')
EN0_IP=$(ipconfig getifaddr en0 2>/dev/null)
if [ -n "$EN0_IP" ]; then
    WIFI=$(networksetup -getairportpower en0 2>/dev/null | grep -i "on")
    [ -n "$WIFI" ] && CONN="Wi-Fi" || CONN="Ethernet"
    SSID_RAW=$(networksetup -getairportnetwork en0 2>/dev/null | sed 's/Current Wi-Fi Network: //')
    echo "$SSID_RAW" | grep -q "not associated" && SSID="" || SSID="$SSID_RAW"
else
    CONN="Offline"; SSID=""
fi

# Speicher
DISK_TOTAL=$(diskutil apfs list 2>/dev/null | grep "Size (Capacity Ceiling)" | head -1 | grep -o '([0-9.]* GB)' | tr -d '()')
DISK_USED=$(diskutil apfs list 2>/dev/null | grep "Capacity In Use" | head -1 | grep -o '([0-9.]* GB)' | tr -d '()')
DISK_FREE=$(diskutil apfs list 2>/dev/null | grep "Capacity Not Allocated" | head -1 | grep -o '([0-9.]* GB)' | tr -d '()')
PCT=$(diskutil apfs list 2>/dev/null | grep "Capacity In Use" | head -1 | grep -o '[0-9.]*%' | tr -d '%' | cut -d. -f1)

BAR=""
BAR_W=25
FILLED=$((PCT * BAR_W / 100))
if [ "$PCT" -gt 90 ]; then BC="$R"; elif [ "$PCT" -gt 70 ]; then BC="$Y"; else BC="$G"; fi
for ((i=0; i<FILLED; i++)); do BAR+="━"; done
BAR="${BC}${BAR}${GR}"
for ((i=FILLED; i<BAR_W; i++)); do BAR+="─"; done
BAR+="$N"

# RAM Usage
RAM_USED_PAGES=$(vm_stat 2>/dev/null | awk '/Pages active/{gsub(/\./,"",$3); print $3}')
RAM_WIRED_PAGES=$(vm_stat 2>/dev/null | awk '/Pages wired/{gsub(/\./,"",$4); print $4}')
RAM_COMP_PAGES=$(vm_stat 2>/dev/null | awk '/Pages occupied by compressor/{gsub(/\./,"",$6); print $6}')
RAM_USED_GB=$(echo "scale=1; (${RAM_USED_PAGES:-0} + ${RAM_WIRED_PAGES:-0} + ${RAM_COMP_PAGES:-0}) * 16384 / 1073741824" | bc 2>/dev/null || echo "?")
RAM_PCT=$(echo "scale=0; ${RAM_USED_GB:-0} * 100 / $RAM_GB" | bc 2>/dev/null || echo "?")

# Akku
BATT_INFO=$(pmset -g batt 2>/dev/null)
BATT_PCT=$(echo "$BATT_INFO" | grep -o '[0-9]*%' | head -1 | tr -d '%')
BATT_STATE=$(echo "$BATT_INFO" | grep -o 'charging\|discharging\|charged' | head -1)
case $BATT_STATE in
    "charging") BATT_ICON="⚡"; BATT_TXT="Laden" ;;
    "discharging") BATT_ICON="🔋"; BATT_TXT="Akku" ;;
    "charged") BATT_ICON="✓"; BATT_TXT="Voll" ;;
    *) BATT_ICON="?"; BATT_TXT="—" ;;
esac
BATT_BAR=""
BATT_FILLED=$((BATT_PCT * 10 / 100))
if [ "$BATT_PCT" -lt 20 ]; then BATT_C="$R"; elif [ "$BATT_PCT" -lt 50 ]; then BATT_C="$Y"; else BATT_C="$G"; fi
for ((i=0; i<BATT_FILLED; i++)); do BATT_BAR+="━"; done
BATT_BAR="${BATT_C}${BATT_BAR}${GR}"
for ((i=BATT_FILLED; i<10; i++)); do BATT_BAR+="─"; done
BATT_BAR+="$N"

# Uptime & Load
UPTIME=$(uptime | sed 's/.*up //' | sed 's/,.*//' | xargs)
LOAD=$(uptime | sed 's/.*load averages: //' | awk '{print $1, $2, $3}')

# Top Prozesse (CPU)
TOP_PROCS=$(ps aux --sort=-%cpu 2>/dev/null | head -4 | tail -3 | awk '{printf "%-16s %s%%\n", $11, $3}' | sed 's|.*/||' | head -3)
if [ -z "$TOP_PROCS" ]; then
    TOP_PROCS=$(ps -Arco pid,%cpu,comm | head -4 | tail -3 | awk '{printf "%-16s %s%%\n", $3, $2}')
fi
TOP1=$(echo "$TOP_PROCS" | sed -n '1p')
TOP2=$(echo "$TOP_PROCS" | sed -n '2p')
TOP3=$(echo "$TOP_PROCS" | sed -n '3p')

# Ollama
OLLAMA_MODELS=$(ollama list 2>/dev/null | tail -n +2 | awk '{printf "%s (%s %s)\n", $1, $3, $4}')
OL1=$(echo "$OLLAMA_MODELS" | sed -n '1p')
OL2=$(echo "$OLLAMA_MODELS" | sed -n '2p')
OL3=$(echo "$OLLAMA_MODELS" | sed -n '3p')
[ -z "$OL1" ] && OL1="keine Modelle"

# Docker
DOCKER_RUNNING=$(docker ps --format '{{.Names}}' 2>/dev/null | head -3)
D1=$(echo "$DOCKER_RUNNING" | sed -n '1p')
D2=$(echo "$DOCKER_RUNNING" | sed -n '2p')
D3=$(echo "$DOCKER_RUNNING" | sed -n '3p')
DOCKER_COUNT=$(docker ps -q 2>/dev/null | wc -l | xargs)
[ -z "$D1" ] && D1="keine Container"

# ── Layout ─────────────────────────────────────────────────────
W=52

pad() {
    local text="$1" width="$2"
    local stripped=$(echo -e "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local len=${#stripped}
    local spaces=$((width - len))
    [ $spaces -lt 0 ] && spaces=0
    printf "%s%*s" "$text" "$spaces" ""
}

row() {
    echo -e "  $(pad "$1" $W)$(pad "$2" $W)$(pad "$3" $W)"
}

hdr() {
    echo -e "  $(pad "$(echo -e "${C}┌─ ${WH}$1${N}")" $W)$(pad "$(echo -e "${C}┌─ ${WH}$2${N}")" $W)$(pad "$(echo -e "${C}┌─ ${WH}$3${N}")" $W)"
}

v() { echo -e "${WH}$1${N}"; }
d() { echo -e "${GR}$1${N}"; }
l() { echo -e "${D}$1  ${WH}$2${N}"; }

# ── Ausgabe ────────────────────────────────────────────────────
echo ""
echo -e "  ${GR}$(date '+%d.%m.%Y %H:%M')${N}    ${WH}${HOSTNAME}${N} ${GR}·${N} ${D}${OS}${N} ${GR}·${N} ${D}${CPU}${N} ${GR}·${N} ${D}${CORES} Cores${N} ${GR}·${N} ${D}${RAM_GB}GB RAM${N} ${GR}·${N} ${D}${ARCH}${N}"
echo -e "  ${GR}$(printf '%.0s─' {1..154})${N}"
echo ""

hdr "NETZWERK" "SPEICHER" "AKKU"
row "  $(l "IP" "$LOCAL_IP")" "  $(l "Gesamt" "$DISK_TOTAL")" "  ${BATT_ICON} $(v "${BATT_PCT}%") ${BATT_TXT}"
row "  $(l "Extern" "$PUBLIC_IP")" "  $(l "Benutzt" "$DISK_USED") ${GR}(${PCT}%)${N}" "  [${BATT_BAR}]"
row "  $(l "Gateway" "${GATEWAY:-—}")" "  $(l "Frei" "$DISK_FREE")" ""
row "  $(l "DNS" "${DNS:-—}")" "  [${BAR}] " ""
row "  $(l "Verbindung" "$CONN ${SSID:+($SSID)}")" "" ""
echo ""

hdr "TOP PROZESSE (CPU)" "OLLAMA MODELLE" "DOCKER (${DOCKER_COUNT:-0})"
row "  ${GR}$TOP1${N}" "  $(v "$OL1")" "  $(v "$D1")"
row "  ${GR}$TOP2${N}" "  $(v "$OL2")" "  $(v "$D2")"
row "  ${GR}$TOP3${N}" "  $(v "$OL3")" "  $(v "$D3")"
echo ""
echo -e "  ${GR}Uptime ${WH}${UPTIME}${N}  ${GR}·  Load ${WH}${LOAD}${N}  ${GR}·  RAM ${WH}${RAM_USED_GB}/${RAM_GB} GB${N} ${GR}(${RAM_PCT}%)${N}"
echo ""
