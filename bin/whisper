#!/bin/bash

# Whisper Wrapper für whisper.cpp
# Nutzung: whisper <audio-datei> [modell]

MODELS_DIR="$HOME/.whisper"
DEFAULT_MODEL="large-v3"

# Farben
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Hilfe
if [[ "$1" == "-h" || "$1" == "--help" || -z "$1" ]]; then
    echo -e "${GREEN}Whisper - Speech-to-Text${NC}"
    echo ""
    echo "Nutzung: whisper <audio-datei> [modell]"
    echo ""
    echo "Modelle:"
    echo "  base      - Schnell, okay Qualität (~142MB)"
    echo "  large-v3  - Langsamer, beste Qualität (~3GB) [Standard]"
    echo ""
    echo "Beispiele:"
    echo "  whisper audio.mp3"
    echo "  whisper interview.wav base"
    echo "  whisper podcast.m4a large-v3"
    echo ""
    echo "Optionen:"
    echo "  -l, --list    Zeige installierte Modelle"
    echo ""
    exit 0
fi

# Liste Modelle
if [[ "$1" == "-l" || "$1" == "--list" ]]; then
    echo -e "${GREEN}Installierte Modelle:${NC}"
    ls -lh "$MODELS_DIR"/*.bin 2>/dev/null | awk '{print "  " $NF " (" $5 ")"}'
    exit 0
fi

# Audio-Datei
AUDIO_FILE="$1"
MODEL="${2:-$DEFAULT_MODEL}"
MODEL_FILE="$MODELS_DIR/ggml-${MODEL}.bin"

# Prüfe Audio-Datei
if [[ ! -f "$AUDIO_FILE" ]]; then
    echo -e "${RED}Fehler: Datei '$AUDIO_FILE' nicht gefunden${NC}"
    exit 1
fi

# Prüfe Modell
if [[ ! -f "$MODEL_FILE" ]]; then
    echo -e "${RED}Fehler: Modell '$MODEL' nicht gefunden${NC}"
    echo -e "Verfügbare Modelle:"
    ls "$MODELS_DIR"/*.bin 2>/dev/null | xargs -I{} basename {} .bin | sed 's/ggml-/  /'
    exit 1
fi

# Konvertiere zu WAV falls nötig (whisper.cpp braucht 16kHz WAV)
TEMP_WAV=""
if [[ "${AUDIO_FILE##*.}" != "wav" ]]; then
    echo -e "${YELLOW}Konvertiere zu WAV...${NC}"
    TEMP_WAV=$(mktemp /tmp/whisper_XXXXXX.wav)
    ffmpeg -i "$AUDIO_FILE" -ar 16000 -ac 1 -c:a pcm_s16le "$TEMP_WAV" -y -loglevel error
    if [[ $? -ne 0 ]]; then
        echo -e "${RED}Fehler: Konvertierung fehlgeschlagen. Ist ffmpeg installiert?${NC}"
        echo "Installiere mit: brew install ffmpeg"
        rm -f "$TEMP_WAV"
        exit 1
    fi
    AUDIO_FILE="$TEMP_WAV"
fi

# Transkribiere
echo -e "${GREEN}Transkribiere mit Modell: ${MODEL}${NC}"
echo ""

/opt/homebrew/opt/whisper-cpp/bin/whisper-cli -m "$MODEL_FILE" -f "$AUDIO_FILE" -l de --print-colors 2>/dev/null

# Aufräumen
if [[ -n "$TEMP_WAV" ]]; then
    rm -f "$TEMP_WAV"
fi
