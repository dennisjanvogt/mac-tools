import json, os
from datetime import datetime, timezone

f = os.path.expanduser("$CARDS")
try: data = json.load(open(f))
except: data = {"cards":[]}
# Replace existing kanban card
data["cards"] = [c for c in data["cards"] if c.get("id") != "kanban_sync"]
data["cards"].append({
    "id": "kanban_sync",
    "title": "Kanban",
    "content": "",
    "items": [],
    "icon": "checklist",
    "color": "purple",
    "type": "kanban",
    "sub": "",
    "timestamp": datetime.now(timezone.utc).isoformat(),
})
json.dump(data, open(f,"w"), ensure_ascii=False, indent=2)
print("Kanban-Card hinzugefügt (live sync)")
