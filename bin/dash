        ;;
    youtube|yt)
        shift
        download=0
        if [ "$1" = "-d" ] || [ "$1" = "--download" ]; then
            download=1; shift
        fi
        [ -z "$1" ] && echo "Usage: dash youtube [-d] <url|suchbegriff>" && exit 1
        input="$*"
        DOWNLOAD=$download python3 << PYEOF
import json, os, re, subprocess, time

inp = """$input""".strip()
download = os.environ.get("DOWNLOAD") == "1"

def extract_id(s):
    s = s.strip()
    pats = [
        r"(?:youtube\.com/watch\?[^#]*v=|youtu\.be/|youtube\.com/embed/|youtube\.com/shorts/|youtube\.com/live/)([A-Za-z0-9_-]{11})",
        r"^([A-Za-z0-9_-]{11})$",
    ]
    for p in pats:
        m = re.search(p, s)
        if m: return m.group(1)
    return None

vid = extract_id(inp)
title = None
channel = None
stream = None
downloaded_path = None

target = f"https://www.youtube.com/watch?v={vid}" if vid else f"ytsearch1:{inp}"
# Progressive (single-file) formats only — AVPlayer needs a direct MP4 url; HLS from
# googlevideo renders audio-only in AVPlayer on macOS. itag 18 is the only reliable
# progressive MP4 with audio+video on YouTube (360p avc1+AAC).
stream_fmt = "18/best[protocol^=http][ext=mp4][acodec!=none][vcodec!=none]/best[acodec!=none][vcodec!=none]"
# For explicit downloads we can merge streams and go higher.
dl_fmt = "bv*[height<=1080][ext=mp4]+ba[ext=m4a]/b[height<=1080][ext=mp4]/b[height<=1080]"

try:
    r = subprocess.run(
        ["yt-dlp", "--skip-download", "--no-warnings",
         "-f", stream_fmt,
         "--print", "%(id)s\t%(title)s\t%(uploader)s\t%(url)s",
         target],
        capture_output=True, text=True, timeout=30
    )
    line = (r.stdout or "").strip().split("\n")[0]
    parts = line.split("\t")
    if len(parts) >= 1 and parts[0]:
        vid = parts[0]
        if len(parts) > 1: title = parts[1]
        if len(parts) > 2: channel = parts[2]
        if len(parts) > 3: stream = parts[3].split("\n")[0]
except Exception as e:
    print(f"yt-dlp Fehler: {e}"); raise SystemExit(1)

if not vid:
    print(f"Kein Video gefunden: {inp}"); raise SystemExit(1)

if download:
    dl_dir = os.path.expanduser("~/.cache/dashboard/youtube")
    os.makedirs(dl_dir, exist_ok=True)
    out_tmpl = os.path.join(dl_dir, f"{vid}.%(ext)s")
    print(f"Download {vid} (<=720p)...")
    r = subprocess.run(
        ["yt-dlp", "--no-warnings", "--no-progress",
         "-f", dl_fmt,
         "--merge-output-format", "mp4",
         "-o", out_tmpl,
         f"https://www.youtube.com/watch?v={vid}"],
        capture_output=True, text=True, timeout=600
    )
    if r.returncode != 0:
        print("Download fehlgeschlagen:")
        print(r.stderr[-500:])
        raise SystemExit(1)
    for ext in ("mp4", "mkv", "webm", "m4a"):
        cand = os.path.join(dl_dir, f"{vid}.{ext}")
        if os.path.exists(cand):
            downloaded_path = cand
            break
    if not downloaded_path:
        print("Download-Datei nicht gefunden"); raise SystemExit(1)
    stream = f"file://{downloaded_path}"
elif not stream:
    print(f"Keine Stream-URL aufgelöst für {vid}"); raise SystemExit(1)

if not title: title = inp

f = os.path.expanduser("$CARDS")
try: data = json.load(open(f))
except: data = {"cards":[]}

import datetime as _dt
now = _dt.datetime.now(_dt.timezone.utc).isoformat()
cid = f"youtube_{vid}_{time.time_ns()}"
card = {
    "id": cid,
    "title": title[:80],
    "content": "offline" if downloaded_path else "stream",
    "icon": "arrow.down.circle.fill" if downloaded_path else "play.rectangle.fill",
    "color": "green" if downloaded_path else "red",
    "type": "youtube",
    "videoId": vid,
    "streamUrl": stream,
    "timestamp": now,
}
if channel: card["sub"] = channel
data["cards"].append(card)
json.dump(data, open(f, "w"), ensure_ascii=False, indent=2)
print(f"YouTube: {title} ({vid})")
