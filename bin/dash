f = os.path.expanduser("$CARDS")
try: data = json.load(open(f))
except: data = {"cards":[]}
cid = "news_" + "$query".replace(" ","_")[:15]
cid = cid + "_" + str(__import__('time').time_ns())
data["cards"].append({"id":cid,"title":"News: $query","content":"","items":items,"icon":"newspaper","color":"rose","type":"list","sub":f'{len(items)} Artikel'})
json.dump(data, open(f,"w"), ensure_ascii=False, indent=2)
print(f"News: {len(items)} Artikel")
PYEOF
        ;;
    images)
        [ -z "$2" ] && echo "Usage: dash images <query>" && exit 1
        shift
        query="$*"
        python3 << PYEOF
import json, subprocess, os, urllib.parse

key_file = open(os.path.expanduser("~/.config/keys/search.env")).read()
keys = dict(l.split("=",1) for l in key_file.strip().split("\n") if "=" in l)
serper = keys.get("SERPER_API_KEY","")

r = subprocess.run(["curl", "-s", "--max-time", "8",
    "https://google.serper.dev/images",
    "-H", f"X-API-KEY: {serper}",
    "-H", "Content-Type: application/json",
    "-d", json.dumps({"q": "$query", "gl": "de", "num": 6})
], capture_output=True, text=True)
d = json.loads(r.stdout)

items = []
for img in d.get("images", [])[:6]:
    title = img.get("title","")[:60]
    link = img.get("imageUrl","")
    items.append(f"{title}\n{link}")

f = os.path.expanduser("$CARDS")
